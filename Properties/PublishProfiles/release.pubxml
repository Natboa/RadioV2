<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile for RadioV2 distribution builds.
  Self-contained: .NET runtime is bundled, no install required on target machine.
  Output: ./publish/ — this folder is packaged by Inno Setup.

  Usage:
    dotnet publish -c Release -r win-x64 --self-contained true -o ./publish
  Or via Visual Studio: Publish → release profile.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>false</IncludeNativeLibrariesForSelfExtract>
    <PublishDir>publish\</PublishDir>
    <PublishReadyToRun>true</PublishReadyToRun>
    <TieredCompilation>true</TieredCompilation>
  </PropertyGroup>
</Project>
