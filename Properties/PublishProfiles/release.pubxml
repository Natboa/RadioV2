<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile for RadioV2 distribution builds.
  Framework-dependent: the installer handles .NET runtime installation.
  Output: ./publish/ — this folder is packaged by Inno Setup.

  Usage:
    dotnet publish -c Release -r win-x64 --self-contained false -o ./publish
  Or via Visual Studio: Publish → release profile.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>false</IncludeNativeLibrariesForSelfExtract>
    <PublishDir>publish\</PublishDir>
    <PublishReadyToRun>true</PublishReadyToRun>
    <TieredCompilation>true</TieredCompilation>
  </PropertyGroup>
</Project>
