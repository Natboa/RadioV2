<UserControl x:Class="RadioV2.DevTool.Views.StationsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:RadioV2.DevTool.ViewModels">
    <UserControl.DataContext>
        <vm:StationsViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" MinWidth="200" />
            <ColumnDefinition Width="4" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: Search + filter + list -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0"
                     Margin="8,8,8,4"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Grid.Row="1"
                      Margin="8,0,8,4"
                      ItemsSource="{Binding GroupFilter}"
                      SelectedItem="{Binding SelectedGroupFilter}"
                      DisplayMemberPath="Name" />

            <ListBox Grid.Row="2"
                     Margin="8,0,8,0"
                     ItemsSource="{Binding Stations}"
                     SelectedItem="{Binding SelectedStation}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2,4">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Group.Name}"
                                       FontSize="11"
                                       Opacity="0.6" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Grid.Row="3"
                    Margin="8,4,8,0"
                    Content="Load More"
                    Command="{Binding LoadMoreCommand}"
                    Visibility="{Binding HasMore, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Button Grid.Row="4"
                    Margin="8,4,8,8"
                    Content="+ New Station"
                    Command="{Binding NewStationCommand}" />
        </Grid>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" />

        <!-- RIGHT: Edit / Create form -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16" MaxWidth="500">
                <TextBlock Text="{Binding IsEditMode, Converter={StaticResource BoolToModeConverter}}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16" />

                <TextBlock Text="Name" Opacity="0.7" Margin="0,0,0,2" />
                <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" />

                <TextBlock Text="Stream URL" Opacity="0.7" Margin="0,0,0,2" />
                <TextBox Text="{Binding FormStreamUrl, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" />

                <TextBlock Text="Logo URL (optional)" Opacity="0.7" Margin="0,0,0,2" />
                <TextBox Text="{Binding FormLogoUrl, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" />

                <TextBlock Text="Group" Opacity="0.7" Margin="0,0,0,2" />
                <ComboBox ItemsSource="{Binding Groups}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding FormGroupId}"
                          Margin="0,0,0,12" />

                <CheckBox Content="Is Favourite"
                          IsChecked="{Binding FormIsFavorite}"
                          Margin="0,0,0,16" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E74C3C"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="Save"
                            Width="100"
                            Margin="0,0,8,0"
                            Command="{Binding SaveCommand}" />
                    <Button Content="Delete Station"
                            Width="120"
                            Background="#C0392B"
                            Foreground="White"
                            Command="{Binding DeleteStationCommand}"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
