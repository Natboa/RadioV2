<UserControl x:Class="RadioV2.DevTool.Views.GroupsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:RadioV2.DevTool.ViewModels">
    <UserControl.DataContext>
        <vm:GroupsViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="200" />
            <ColumnDefinition Width="4" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: Search + group list + new button -->
        <Grid Grid.Column="0" IsEnabled="{Binding IsNotBusy}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0"
                     Margin="8,8,8,4"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <ListBox Grid.Row="1"
                     Margin="8,0,8,0"
                     ItemsSource="{Binding Groups}"
                     SelectedItem="{Binding SelectedGroup}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2,4">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock FontSize="11" Opacity="0.6">
                                <Run Text="{Binding StationCount, StringFormat='{}{0:N0} stations'}" />
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Grid.Row="2"
                    Margin="8,4,8,8"
                    Content="+ New Group"
                    Command="{Binding NewGroupCommand}" />
        </Grid>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" />

        <!-- RIGHT: Group form + merge section -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" IsEnabled="{Binding IsNotBusy}">
            <StackPanel Margin="16" MaxWidth="460">
                <TextBlock Text="{Binding IsEditMode, Converter={StaticResource BoolToModeConverter}, ConverterParameter=Group}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16" />

                <TextBlock Text="Group Name" Opacity="0.7" Margin="0,0,0,2" />
                <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E74C3C"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <Button Content="Save"
                            Width="90"
                            Margin="0,0,8,0"
                            Command="{Binding SaveCommand}" />
                    <Button Content="Delete Group"
                            Width="110"
                            Background="#C0392B"
                            Foreground="White"
                            Command="{Binding DeleteGroupCommand}"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>

                <!-- Merge section -->
                <Separator Margin="0,0,0,16"
                           Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Merge into another group"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <TextBlock Opacity="0.7" Margin="0,0,0,2">
                        <Run Text="Move all stations from '" /><Run Text="{Binding SelectedGroup.Name}" FontWeight="SemiBold" /><Run Text="' into:" />
                    </TextBlock>

                    <TextBox Text="{Binding MergeSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,4,0,4" />

                    <ComboBox ItemsSource="{Binding MergeTargets}"
                              SelectedItem="{Binding MergeTargetGroup}"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,12" />

                    <Button Content="Merge Groups"
                            Width="130"
                            HorizontalAlignment="Left"
                            Command="{Binding MergeGroupsCommand}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        <!-- Busy overlay -->
        <Grid Grid.Column="0" Grid.ColumnSpan="3"
              Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="#80000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="6" Margin="0,0,0,12" />
                <TextBlock Text="Working…" Foreground="White" FontSize="14"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
