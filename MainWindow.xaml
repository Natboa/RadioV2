<ui:FluentWindow x:Class="RadioV2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:RadioV2.Views"
        xmlns:controls="clr-namespace:RadioV2.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RadioV2"
        Icon="Assets/RadioV2_Logo.ico"
        Width="1100" Height="700"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" x:Name="MainTitleBar" Title="RadioV2">
            <ui:TitleBar.TrailingContent>
                <Button Click="OnHideToTrayClick"
                        ToolTip="Minimize to tray"
                        Width="46" Height="32"
                        Padding="0"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Arrow">
                    <ui:SymbolIcon Symbol="ArrowMinimize24" FontSize="11" />
                </Button>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <!-- Update available banner — hidden until UpdateCheckerService finds a newer release -->
        <Border Grid.Row="1"
                x:Name="UpdateBanner"
                Visibility="Collapsed"
                Background="{ui:ThemeResource SystemFillColorAttentionBackgroundBrush}"
                BorderBrush="{ui:ThemeResource SystemFillColorAttentionBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Grid.Column="0" Symbol="Info24" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" x:Name="UpdateBannerText"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <ui:Button Grid.Column="2" Content="Download"
                           Appearance="Primary"
                           Margin="8,0,4,0"
                           Click="OnDownloadUpdateClick" />
                <Button Grid.Column="3"
                        Background="Transparent" BorderThickness="0"
                        VerticalAlignment="Center"
                        Click="OnDismissUpdateBannerClick"
                        ToolTip="Dismiss">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" />
                </Button>
            </Grid>
        </Border>

        <ui:NavigationView Grid.Row="2"
            x:Name="RootNavigation"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleVisible="False"
            TransitionDuration="0">
            <ui:NavigationView.PaneHeader>
                <Border Height="44" />
            </ui:NavigationView.PaneHeader>
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Browse"
                    TargetPageType="{x:Type views:BrowsePage}"
                    Icon="{ui:SymbolIcon Search24}" />
                <ui:NavigationViewItem Content="Discover"
                    TargetPageType="{x:Type views:DiscoverPage}"
                    Icon="{ui:SymbolIcon Globe24}" />
                <ui:NavigationViewItem Content="Favourites"
                    TargetPageType="{x:Type views:FavouritesPage}"
                    Icon="{ui:SymbolIcon Heart24}" />
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Settings"
                    TargetPageType="{x:Type views:SettingsPage}"
                    Icon="{ui:SymbolIcon Settings24}" />
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <!-- Custom pane toggle: diagonal arrows, floats at right edge of pane -->
        <Button Grid.Row="2"
                x:Name="PaneToggleBtn"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Width="36" Height="36"
                Margin="0,8,0,0"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Click="OnPaneToggleClick">
            <ui:SymbolIcon x:Name="PaneToggleIcon"
                           Symbol="FullScreenMinimize20"
                           FontSize="14"/>
        </Button>

        <Border Grid.Row="3" Height="72"
                Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                CornerRadius="8,8,0,0">
            <controls:MiniPlayer x:Name="MiniPlayerControl" />
        </Border>

        <!-- Snackbar presenter for playback errors and notifications -->
        <ui:SnackbarPresenter x:Name="RootSnackbar"
                              Grid.Row="0" Grid.RowSpan="4"
                              VerticalAlignment="Bottom"
                              Margin="16,0,16,80" />
    </Grid>

</ui:FluentWindow>
