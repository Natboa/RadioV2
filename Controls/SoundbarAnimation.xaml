<UserControl x:Class="RadioV2.Controls.SoundbarAnimation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="16" d:DesignWidth="13"
             Visibility="Collapsed">

    <Grid Width="13" Height="16">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
            <Rectangle x:Name="Bar1" Width="3" Height="14" RadiusX="1.5" RadiusY="1.5"
                       RenderTransformOrigin="0.5,1">
                <Rectangle.RenderTransform>
                    <ScaleTransform ScaleY="0.2" />
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle x:Name="Bar2" Width="3" Height="14" RadiusX="1.5" RadiusY="1.5"
                       Margin="2,0,0,0" RenderTransformOrigin="0.5,1">
                <Rectangle.RenderTransform>
                    <ScaleTransform ScaleY="0.2" />
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle x:Name="Bar3" Width="3" Height="14" RadiusX="1.5" RadiusY="1.5"
                       Margin="2,0,0,0" RenderTransformOrigin="0.5,1">
                <Rectangle.RenderTransform>
                    <ScaleTransform ScaleY="0.2" />
                </Rectangle.RenderTransform>
            </Rectangle>
        </StackPanel>
    </Grid>
</UserControl>
