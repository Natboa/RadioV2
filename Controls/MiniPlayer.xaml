<UserControl x:Class="RadioV2.Controls.MiniPlayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="72" d:DesignWidth="1100">

    <UserControl.Resources>
        <Storyboard x:Key="PlayPulse">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1" To="1.22" Duration="0:0:0.09" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1" To="1.22" Duration="0:0:0.09" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Logo + Station info -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="8,0">

            <Border Width="40" Height="40"
                    CornerRadius="4"
                    Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                    Margin="0,0,10,0">
                <Image Source="{Binding StationLogoUrl}"
                       Stretch="UniformToFill"
                       Width="40" Height="40" />
            </Border>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding StationName}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="320"
                           ToolTip="{Binding StationName}" />
                <TextBlock Text="{Binding NowPlayingDisplay}"
                           FontSize="11"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="320"
                           ToolTip="{Binding NowPlayingDisplay}"
                           Visibility="{Binding HasNowPlaying, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </StackPanel>

        <!-- Center: Playback controls -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <ui:Button Appearance="Transparent"
                       Command="{Binding PreviousStationCommand}"
                       ToolTip="Previous">
                <ui:SymbolIcon Symbol="Previous24" />
            </ui:Button>

            <ui:Button x:Name="PlayPauseBtn"
                       Appearance="Primary"
                       Command="{Binding PlayPauseCommand}"
                       Margin="4,0"
                       ToolTip="Play / Pause"
                       RenderTransformOrigin="0.5,0.5">
                <ui:Button.RenderTransform>
                    <ScaleTransform />
                </ui:Button.RenderTransform>
                <ui:SymbolIcon Symbol="{Binding IsPlaying, Converter={StaticResource BoolToPlayIconConverter}}" />
            </ui:Button>

            <ui:Button Appearance="Transparent"
                       Command="{Binding NextStationCommand}"
                       ToolTip="Next">
                <ui:SymbolIcon Symbol="Next24" />
            </ui:Button>
        </StackPanel>

        <!-- Right: Volume + Mute + Favourite -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,0,16,0">

            <ui:Button Appearance="Transparent"
                       Command="{Binding ToggleMuteCommand}"
                       ToolTip="Mute / Unmute">
                <ui:SymbolIcon Symbol="{Binding IsMuted, Converter={StaticResource BoolToSpeakerIconConverter}}" />
            </ui:Button>

            <ui:Button x:Name="FavouriteBtn"
                       Appearance="Transparent"
                       ToolTip="Favourite / Unfavourite"
                       Margin="0,0,4,0"
                       Click="FavouriteBtn_Click">
                <Grid>
                    <ui:SymbolIcon Symbol="Heart24"
                                   Filled="False"
                                   Visibility="{Binding IsFavourite, Converter={StaticResource BoolToInverseVisibilityConverter}}" />
                    <ui:SymbolIcon Symbol="Heart24"
                                   Filled="True"
                                   Foreground="Red"
                                   Visibility="{Binding IsFavourite, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </ui:Button>

            <Slider Value="{Binding Volume}"
                    Minimum="0" Maximum="100"
                    Width="120"
                    VerticalAlignment="Center"
                    Margin="4,0,12,0"
                    IsMoveToPointEnabled="True">
                <Slider.Style>
                    <Style TargetType="Slider" BasedOn="{StaticResource {x:Type Slider}}">
                        <Style.Triggers>
                            <!--  Override template to fix track margin so the visible circle aligns with track endpoints  -->
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Slider}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <!--  Margin="10,0" insets the track line by half the thumb width so it ends where the circle ends  -->
                                                <Border
                                                    x:Name="TrackBackground"
                                                    Grid.Row="1"
                                                    Height="4"
                                                    Margin="10,0"
                                                    Background="{DynamicResource SliderTrackFill}"
                                                    BorderThickness="0"
                                                    CornerRadius="2" />
                                                <Track x:Name="PART_Track" Grid.Row="1">
                                                    <Track.DecreaseRepeatButton>
                                                        <RepeatButton Command="Slider.DecreaseLarge" Style="{StaticResource UiSliderButtonStyle}" />
                                                    </Track.DecreaseRepeatButton>
                                                    <Track.Thumb>
                                                        <Thumb x:Name="Thumb" Style="{StaticResource UiSliderThumbStyle}" />
                                                    </Track.Thumb>
                                                    <Track.IncreaseRepeatButton>
                                                        <RepeatButton Command="Slider.IncreaseLarge" Style="{StaticResource UiSliderButtonStyle}" />
                                                    </Track.IncreaseRepeatButton>
                                                </Track>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="TrackBackground" Property="Background" Value="{DynamicResource SliderTrackFillPointerOver}" />
                                                    <Setter TargetName="Thumb" Property="Foreground" Value="{DynamicResource SliderThumbBackgroundPointerOver}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Slider.Style>
            </Slider>

        </StackPanel>
    </Grid>
</UserControl>
