<UserControl x:Class="RadioV2.Controls.MiniPlayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="72" d:DesignWidth="1100">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Logo + Station info -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="8,0">

            <Border Width="40" Height="40"
                    CornerRadius="4"
                    Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                    Margin="0,0,10,0">
                <Image Source="{Binding StationLogoUrl}"
                       Stretch="UniformToFill"
                       Width="40" Height="40" />
            </Border>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding StationName}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="200" />
                <TextBlock Text="{Binding NowPlayingDisplay}"
                           FontSize="11"
                           Opacity="0.7"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="200"
                           Visibility="{Binding HasNowPlaying, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </StackPanel>

        <!-- Center: Playback controls -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <ui:Button Appearance="Transparent"
                       Command="{Binding PreviousStationCommand}"
                       ToolTip="Previous">
                <ui:SymbolIcon Symbol="Previous24" />
            </ui:Button>

            <ui:Button Appearance="Primary"
                       Command="{Binding PlayPauseCommand}"
                       Margin="4,0"
                       ToolTip="Play / Pause">
                <ui:SymbolIcon Symbol="{Binding IsPlaying, Converter={StaticResource BoolToPlayIconConverter}}" />
            </ui:Button>

            <ui:Button Appearance="Transparent"
                       Command="{Binding StopCommand}"
                       Margin="0,0,4,0"
                       ToolTip="Stop">
                <ui:SymbolIcon Symbol="Stop24" />
            </ui:Button>

            <ui:Button Appearance="Transparent"
                       Command="{Binding NextStationCommand}"
                       ToolTip="Next">
                <ui:SymbolIcon Symbol="Next24" />
            </ui:Button>
        </StackPanel>

        <!-- Right: Volume + Mute + Favourite -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,0,16,0">

            <ui:Button Appearance="Transparent"
                       Command="{Binding ToggleMuteCommand}"
                       ToolTip="Mute">
                <ui:SymbolIcon Symbol="Speaker224" />
            </ui:Button>

            <Slider Value="{Binding Volume}"
                    Minimum="0" Maximum="100"
                    Width="120"
                    VerticalAlignment="Center"
                    Margin="4,0,12,0" />

        </StackPanel>
    </Grid>
</UserControl>
