<Page x:Class="RadioV2.Views.FavouritesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:RadioV2.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Title="Favourites">

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Favourites"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"
                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />

        <!-- Favourites list -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Favourites}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Visibility="{Binding IsEmpty, Converter={StaticResource BoolToInverseVisibilityConverter}}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,16,0" />
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <controls:StationListItem HoverOnlyHeart="True" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Empty state -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
            <ui:SymbolIcon Symbol="HeartOff24"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="No favourites yet."
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,4"
                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="Browse or Discover stations and click the heart to save them here."
                       FontSize="13"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</Page>
