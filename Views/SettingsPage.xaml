<Page x:Class="RadioV2.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Title="Settings">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title (sticky — outside scroll) -->
        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Margin="24,16,24,12"
                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,0,24,16" MaxWidth="640" HorizontalAlignment="Left">

            <!-- Appearance card -->
            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Appearance"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"
                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />

                    <DockPanel LastChildFill="False" Margin="0,0,0,12">
                        <TextBlock Text="Theme"
                                   VerticalAlignment="Center"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <RadioButton Content="Light"
                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource StringEqualConverter}, ConverterParameter=Light}"
                                         Margin="0,0,8,0"
                                         GroupName="ThemeGroup" />
                            <RadioButton Content="Dark"
                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource StringEqualConverter}, ConverterParameter=Dark}"
                                         GroupName="ThemeGroup" />
                        </StackPanel>
                    </DockPanel>

                    <DockPanel LastChildFill="False">
                        <TextBlock Text="Clock"
                                   VerticalAlignment="Center"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                        <ui:ToggleSwitch DockPanel.Dock="Right"
                                         IsChecked="{Binding IsClockEnabled}" />
                    </DockPanel>
                </StackPanel>
            </ui:Card>

            <!-- Import Stations card -->
            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Import Stations"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"
                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="Add new stations to the database from an M3U or M3U8 playlist file."
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />

                    <ui:Button Content="Browse for M3U file..."
                               Appearance="Primary"
                               Command="{Binding ImportStationsCommand}" />

                    <Border CornerRadius="6"
                            Background="{ui:ThemeResource SystemFillColorSuccessBackgroundBrush}"
                            Padding="12,8"
                            Margin="0,12,0,0"
                            Visibility="{Binding HasImportStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding ImportStatusMessage}"
                                   FontSize="13"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                    </Border>
                </StackPanel>
            </ui:Card>

            <!-- Favourites card -->
            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Favourites"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"
                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="Import or export your saved stations as an M3U playlist or JSON file."
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />

                    <StackPanel Orientation="Horizontal">
                        <ui:Button Command="{Binding ImportFavouritesCommand}"
                                   Appearance="Secondary"
                                   Margin="0,0,8,0"
                                   ToolTip="Import favourites from M3U or JSON">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,6,0" />
                                <TextBlock Text="Import" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Command="{Binding ExportFavouritesCommand}"
                                   Appearance="Secondary"
                                   ToolTip="Export favourites to M3U or JSON">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowUpload24" Margin="0,0,6,0" />
                                <TextBlock Text="Export" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>

                    <Border CornerRadius="6"
                            Background="{ui:ThemeResource SystemFillColorSuccessBackgroundBrush}"
                            Padding="12,8"
                            Margin="0,12,0,0"
                            Visibility="{Binding HasFavouritesStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding FavouritesStatusMessage}"
                                   FontSize="13"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                    </Border>
                </StackPanel>
            </ui:Card>

            <!-- Donate card -->
            <ui:Card Margin="0,0,0,16">
                <DockPanel LastChildFill="False">
                    <StackPanel>
                        <TextBlock Text="Support RadioV2"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="If you enjoy the app, consider buying me a coffee!"
                                   FontSize="13"
                                   Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <ui:Button DockPanel.Dock="Right"
                               Appearance="Primary"
                               VerticalAlignment="Center"
                               Click="DonateButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Heart24" Margin="0,0,6,0" />
                            <TextBlock Text="Donate" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:Button>
                </DockPanel>
            </ui:Card>

            <!-- About card -->
            <ui:Card>
                <StackPanel>
                    <TextBlock Text="About"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="RadioV2"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="{Binding AppVersion, StringFormat='Version {0}'}"
                               FontSize="13"
                               Margin="0,2,0,8"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="A Windows desktop radio streaming app with Fluent Design."
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                    <ui:Button Appearance="Secondary"
                               Click="CopyrightButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Info24" Margin="0,0,6,0" />
                            <TextBlock Text="Copyright / DMCA Policy" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ui:Card>

        </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
