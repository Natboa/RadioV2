<Page x:Class="RadioV2.Views.DiscoverPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:RadioV2.Controls"
      xmlns:models="clr-namespace:RadioV2.Models"
      xmlns:helpers="clr-namespace:RadioV2.Helpers"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Discover">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- sticky header -->
            <RowDefinition Height="*" />       <!-- scrollable content -->
        </Grid.RowDefinitions>

        <!-- ── Sticky semi-transparent header ────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{ui:ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,14"
                Panel.ZIndex="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Discover"
                           FontSize="28"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                <ui:TextBox Grid.Column="1"
                            x:Name="DiscoverSearchBox"
                            Width="260"
                            VerticalAlignment="Center"
                            Text="{Binding DiscoverSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Search genres &amp; countries..."
                            Icon="{ui:SymbolIcon Search24}" />
            </Grid>
        </Border>

        <!-- ── Carousel view (categories → groups) ───────────────────────── -->
        <ScrollViewer x:Name="CarouselScrollViewer"
                      Grid.Row="1"
                      Visibility="{Binding IsCarouselVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,16,24,0">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding CategoryRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:DiscoverCarouselRow />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ui:ProgressRing IsIndeterminate="True"
                                 Width="32" Height="32"
                                 Margin="0,8,0,24"
                                 HorizontalAlignment="Center"
                                 Visibility="{Binding ShowLoadingSpinner,
                                     Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </ScrollViewer>

        <!-- ── Search results view (flat group cards matching query) ────────── -->
        <ScrollViewer Grid.Row="1"
                      Visibility="{Binding IsSearchResultsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,16,24,0">
            <ItemsControl ItemsSource="{Binding SearchResultGroups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="CardBorder"
                                Width="160"
                                Margin="0,0,12,12"
                                CornerRadius="8"
                                ClipToBounds="True"
                                Cursor="Hand"
                                Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.SelectGroupCommand,
                                                            RelativeSource={RelativeSource AncestorType=Page}}"
                                              CommandParameter="{Binding}" />
                            </Border.InputBindings>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="160" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" ClipToBounds="True">
                                    <Grid>
                                        <Border Background="{ui:ThemeResource ControlFillColorSecondaryBrush}">
                                            <ui:SymbolIcon Symbol="Play24"
                                                           FontSize="40"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                                        </Border>
                                        <Image x:Name="GroupImage"
                                               Stretch="UniformToFill"
                                               RenderTransformOrigin="0.5,0.5"
                                               Source="{Binding Name, Converter={StaticResource GroupNameToImageConverter}}">
                                            <Image.RenderTransform>
                                                <ScaleTransform x:Name="ImageScale" />
                                            </Image.RenderTransform>
                                        </Image>
                                        <ui:Button x:Name="PlayButton"
                                                   Appearance="Primary"
                                                   Width="36" Height="36"
                                                   CornerRadius="18"
                                                   Padding="0"
                                                   Margin="0,0,8,8"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"
                                                   Visibility="Collapsed"
                                                   Command="{Binding DataContext.SelectGroupCommand,
                                                                 RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}">
                                            <ui:SymbolIcon Symbol="Play24" FontSize="14" />
                                        </ui:Button>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Row="1" Margin="10,8,10,10">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                                    <TextBlock FontSize="11"
                                               Margin="0,2,0,0"
                                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{Binding StationCount, Mode=OneWay}" /><Run Text=" stations" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ImageScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.06" Duration="0:0:0.2" />
                                            <DoubleAnimation Storyboard.TargetName="ImageScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.06" Duration="0:0:0.2" />
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayButton"
                                                                           Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="{x:Static Visibility.Visible}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CardBorder"
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <SolidColorBrush Color="{DynamicResource ControlFillColorSecondary}" />
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ImageScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.0" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="ImageScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.0" Duration="0:0:0.15" />
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayButton"
                                                                           Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="{x:Static Visibility.Collapsed}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CardBorder"
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <SolidColorBrush Color="{DynamicResource ControlFillColorDefault}" />
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Station list view (drill-down into a group) ───────────────── -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsGroupView, Converter={StaticResource BoolToVisibilityConverter}}"
              Margin="24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- back + title -->
                <RowDefinition Height="Auto" />   <!-- search box -->
                <RowDefinition Height="*" />      <!-- virtualized station list (featured + stations together) -->
                <RowDefinition Height="48" />     <!-- spinner — fixed height prevents layout reflow -->
            </Grid.RowDefinitions>

            <!-- Header: back + group name -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,12,0,12">
                <ui:Button Appearance="Transparent"
                           Command="{Binding BackToGroupsCommand}"
                           Margin="0,0,8,0">
                    <ui:SymbolIcon Symbol="ArrowLeft24" />
                </ui:Button>
                <TextBlock Text="{Binding SelectedGroup.Name}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
            </StackPanel>

            <!-- Search within group -->
            <ui:TextBox x:Name="GroupSearchBox"
                        Grid.Row="1"
                        Text="{Binding GroupSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="{Binding SelectedGroup.Name, StringFormat='Filter within {0}...'}"
                        Icon="{ui:SymbolIcon Search24}"
                        Margin="0,0,0,12" />

            <!--
                Single virtualized ListBox for featured + regular stations.
                Featured header, featured station items, separator, and regular station items
                are all objects in AllStationItems — a mixed ObservableCollection<object>.

                By letting the ListBox own its ScrollViewer (no outer SV wrapper), WPF's
                VirtualizingStackPanel can measure against the finite Height="*" viewport and
                only create containers for visible items.  Adding off-screen items is nearly
                free: no container is created until the item scrolls into view.

                DataTemplate DataType matching (in ListBox.Resources) picks the correct
                template per item type.  GroupViewItemStyleSelector gives header/separator
                markers a chrome-free container (no hover, no focus ring) while station
                items get the normal ListBoxItem style.
            -->
            <ListBox x:Name="StationsListBox"
                     Grid.Row="2"
                     ItemsSource="{Binding AllStationItems}"
                     BorderThickness="0"
                     Background="Transparent"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Standard"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyleSelector>
                    <helpers:GroupViewItemStyleSelector>
                        <!-- Normal station row: hover highlight, standard padding -->
                        <helpers:GroupViewItemStyleSelector.StationStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,16,0" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </helpers:GroupViewItemStyleSelector.StationStyle>
                        <!-- Header / separator marker: no chrome, not focusable, no margins -->
                        <helpers:GroupViewItemStyleSelector.MarkerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="IsHitTestVisible" Value="False" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </helpers:GroupViewItemStyleSelector.MarkerStyle>
                    </helpers:GroupViewItemStyleSelector>
                </ListBox.ItemContainerStyleSelector>
                <ListBox.Resources>
                    <DataTemplate DataType="{x:Type models:FeaturedHeaderItem}">
                        <TextBlock Text="Featured"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,4"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type models:SectionSeparatorItem}">
                        <Separator Margin="0,4,16,4" />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type models:StationGroupViewItem}">
                        <!-- Set DataContext to the inner Station so StationListItem bindings
                             (Name, LogoUrl, IsFavorite, etc.) resolve correctly.
                             RelativeSource AncestorType=Page commands still resolve to
                             DiscoverPage.DataContext (DiscoverViewModel) via visual tree. -->
                        <controls:StationListItem DataContext="{Binding Station}" />
                    </DataTemplate>
                </ListBox.Resources>
            </ListBox>

            <!-- Loading spinner — fixed 48px row so show/hide never causes layout reflow -->
            <ui:ProgressRing Grid.Row="3"
                             IsIndeterminate="True"
                             Width="32" Height="32"
                             Margin="0,8"
                             HorizontalAlignment="Center"
                             Visibility="{Binding ShowLoadingSpinner,
                                 Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </Grid>
</Page>
