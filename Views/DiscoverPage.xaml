<Page x:Class="RadioV2.Views.DiscoverPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:RadioV2.Controls"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Discover">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- sticky header -->
            <RowDefinition Height="*" />       <!-- scrollable content -->
        </Grid.RowDefinitions>

        <!-- ── Sticky semi-transparent header ────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{ui:ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,14"
                Panel.ZIndex="1">
            <TextBlock Text="Discover"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
        </Border>

        <!-- ── Carousel view (categories → groups) ───────────────────────── -->
        <ScrollViewer x:Name="CarouselScrollViewer"
                      Grid.Row="1"
                      Visibility="{Binding IsGroupView, Converter={StaticResource BoolToInverseVisibilityConverter}}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,16,24,0">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding CategoryRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:DiscoverCarouselRow />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ui:ProgressRing IsIndeterminate="True"
                                 Width="32" Height="32"
                                 Margin="0,8,0,24"
                                 HorizontalAlignment="Center"
                                 Visibility="{Binding ShowLoadingSpinner,
                                     Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </ScrollViewer>

        <!-- ── Station list view (drill-down into a group) ───────────────── -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsGroupView, Converter={StaticResource BoolToVisibilityConverter}}"
              Margin="24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header: back + group name -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,12,0,12">
                <ui:Button Appearance="Transparent"
                           Command="{Binding BackToGroupsCommand}"
                           Margin="0,0,8,0">
                    <ui:SymbolIcon Symbol="ArrowLeft24" />
                </ui:Button>
                <TextBlock Text="{Binding SelectedGroup.Name}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
            </StackPanel>

            <!-- Search within group -->
            <ui:TextBox Grid.Row="1"
                        Text="{Binding GroupSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="{Binding SelectedGroup.Name, StringFormat='Filter within {0}...'}"
                        Icon="{ui:SymbolIcon Search24}"
                        Margin="0,0,0,12" />

            <!-- Scrollable content: featured + station list -->
            <ScrollViewer x:Name="GroupScrollViewer"
                          Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Featured stations section -->
                    <Border Visibility="{Binding HasFeaturedStations, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Featured"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,8,0,4"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                            <ListBox ItemsSource="{Binding FeaturedStations}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,16,0" />
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <controls:StationListItem />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Separator Margin="0,4,16,4" />
                        </StackPanel>
                    </Border>

                    <!-- Station list -->
                    <ListBox x:Name="StationsListBox"
                             ItemsSource="{Binding GroupStations}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,16,0" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <controls:StationListItem />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ui:ProgressRing IsIndeterminate="True"
                                     Width="32" Height="32"
                                     Margin="0,8,0,24"
                                     HorizontalAlignment="Center"
                                     Visibility="{Binding ShowLoadingSpinner,
                                         Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
