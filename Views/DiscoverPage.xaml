<Page x:Class="RadioV2.Views.DiscoverPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:RadioV2.Controls"
      xmlns:models="clr-namespace:RadioV2.Models"
      xmlns:helpers="clr-namespace:RadioV2.Helpers"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Discover">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- sticky header -->
            <RowDefinition Height="*" />       <!-- scrollable content -->
        </Grid.RowDefinitions>

        <!-- ── Sticky semi-transparent header ────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{ui:ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,14"
                Panel.ZIndex="1">
            <TextBlock Text="Discover"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
        </Border>

        <!-- ── Carousel view (categories → groups) ───────────────────────── -->
        <ScrollViewer x:Name="CarouselScrollViewer"
                      Grid.Row="1"
                      Visibility="{Binding IsGroupView, Converter={StaticResource BoolToInverseVisibilityConverter}}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,16,24,0">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding CategoryRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:DiscoverCarouselRow />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ui:ProgressRing IsIndeterminate="True"
                                 Width="32" Height="32"
                                 Margin="0,8,0,24"
                                 HorizontalAlignment="Center"
                                 Visibility="{Binding ShowLoadingSpinner,
                                     Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </ScrollViewer>

        <!-- ── Station list view (drill-down into a group) ───────────────── -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsGroupView, Converter={StaticResource BoolToVisibilityConverter}}"
              Margin="24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- back + title -->
                <RowDefinition Height="Auto" />   <!-- search box -->
                <RowDefinition Height="*" />      <!-- virtualized station list (featured + stations together) -->
                <RowDefinition Height="48" />     <!-- spinner — fixed height prevents layout reflow -->
            </Grid.RowDefinitions>

            <!-- Header: back + group name -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,12,0,12">
                <ui:Button Appearance="Transparent"
                           Command="{Binding BackToGroupsCommand}"
                           Margin="0,0,8,0">
                    <ui:SymbolIcon Symbol="ArrowLeft24" />
                </ui:Button>
                <TextBlock Text="{Binding SelectedGroup.Name}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
            </StackPanel>

            <!-- Search within group -->
            <ui:TextBox x:Name="GroupSearchBox"
                        Grid.Row="1"
                        Text="{Binding GroupSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="{Binding SelectedGroup.Name, StringFormat='Filter within {0}...'}"
                        Icon="{ui:SymbolIcon Search24}"
                        Margin="0,0,0,12" />

            <!--
                Single virtualized ListBox for featured + regular stations.
                Featured header, featured station items, separator, and regular station items
                are all objects in AllStationItems — a mixed ObservableCollection<object>.

                By letting the ListBox own its ScrollViewer (no outer SV wrapper), WPF's
                VirtualizingStackPanel can measure against the finite Height="*" viewport and
                only create containers for visible items.  Adding off-screen items is nearly
                free: no container is created until the item scrolls into view.

                DataTemplate DataType matching (in ListBox.Resources) picks the correct
                template per item type.  GroupViewItemStyleSelector gives header/separator
                markers a chrome-free container (no hover, no focus ring) while station
                items get the normal ListBoxItem style.
            -->
            <ListBox x:Name="StationsListBox"
                     Grid.Row="2"
                     ItemsSource="{Binding AllStationItems}"
                     BorderThickness="0"
                     Background="Transparent"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Standard"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyleSelector>
                    <helpers:GroupViewItemStyleSelector>
                        <!-- Normal station row: hover highlight, standard padding -->
                        <helpers:GroupViewItemStyleSelector.StationStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,16,0" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </helpers:GroupViewItemStyleSelector.StationStyle>
                        <!-- Header / separator marker: no chrome, not focusable, no margins -->
                        <helpers:GroupViewItemStyleSelector.MarkerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="IsHitTestVisible" Value="False" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </helpers:GroupViewItemStyleSelector.MarkerStyle>
                    </helpers:GroupViewItemStyleSelector>
                </ListBox.ItemContainerStyleSelector>
                <ListBox.Resources>
                    <DataTemplate DataType="{x:Type models:FeaturedHeaderItem}">
                        <TextBlock Text="Featured"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,4"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type models:SectionSeparatorItem}">
                        <Separator Margin="0,4,16,4" />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type models:StationGroupViewItem}">
                        <!-- Set DataContext to the inner Station so StationListItem bindings
                             (Name, LogoUrl, IsFavorite, etc.) resolve correctly.
                             RelativeSource AncestorType=Page commands still resolve to
                             DiscoverPage.DataContext (DiscoverViewModel) via visual tree. -->
                        <controls:StationListItem DataContext="{Binding Station}" />
                    </DataTemplate>
                </ListBox.Resources>
            </ListBox>

            <!-- Loading spinner — fixed 48px row so show/hide never causes layout reflow -->
            <ui:ProgressRing Grid.Row="3"
                             IsIndeterminate="True"
                             Width="32" Height="32"
                             Margin="0,8"
                             HorizontalAlignment="Center"
                             Visibility="{Binding ShowLoadingSpinner,
                                 Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </Grid>
</Page>
