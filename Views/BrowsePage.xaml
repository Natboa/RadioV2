<Page x:Class="RadioV2.Views.BrowsePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:RadioV2.Controls"
      xmlns:helpers="clr-namespace:RadioV2.Helpers"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Browse">

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Browse"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"
                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />

        <!-- Search box -->
        <ui:TextBox Grid.Row="1"
                    x:Name="SearchBox"
                    Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Search stations..."
                    Icon="{ui:SymbolIcon Search24}"
                    Margin="0,0,0,0"
                    GotFocus="SearchBox_GotFocus"
                    LostFocus="SearchBox_LostFocus"
                    KeyDown="SearchBox_KeyDown" />

        <!-- Search history (in-layout, no Popup/overlay) -->
        <Border x:Name="HistoryBorder"
                Grid.Row="2"
                Margin="0,2,0,10"
                Background="{ui:ThemeResource ApplicationBackgroundBrush}"
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="{Binding IsHistoryVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <ListBox x:Name="HistoryList"
                     ItemsSource="{Binding HistoryItems}"
                     BorderThickness="0"
                     Background="Transparent"
                     SelectionChanged="HistoryList_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   Padding="12,8"
                                   FontSize="13"
                                   Cursor="Hand"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Recent Stations -->
        <StackPanel Grid.Row="3"
                    Margin="0,8,0,0"
                    Visibility="{Binding IsRecentVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Recent Stations"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"
                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
            <ListBox ItemsSource="{Binding RecentStations}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MaxHeight="400"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <controls:StationListItem />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </StackPanel>

        <!-- Station list -->
        <ListBox Grid.Row="4"
                 ItemsSource="{Binding Stations}"
                 BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 Visibility="{Binding IsRecentVisible, Converter={StaticResource BoolToInverseVisibilityConverter}}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <controls:StationListItem />
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <i:Interaction.Behaviors>
                <helpers:InfiniteScrollBehavior LoadMoreCommand="{Binding DataContext.LoadMoreCommand, RelativeSource={RelativeSource AncestorType=Page}}" />
            </i:Interaction.Behaviors>
        </ListBox>

        <!-- Loading spinner -->
        <ui:ProgressRing Grid.Row="5"
                         IsIndeterminate="True"
                         Width="32" Height="32"
                         Margin="0,8"
                         HorizontalAlignment="Center"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
    </Grid>
</Page>
